# --- Telegram Bot Configuration ---
# Token dari @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Username Telegram admin yang diizinkan (pisahkan dengan koma)
AUTHORIZED_USERS=kingbhe,umams1

# --- Panel API Configuration (KHFY) ---
# API Key dari panel khfy-store.com
API_KEY=your_api_key_here

# --- Notification Configuration ---
# ID Channel atau Group untuk notifikasi (Gunakan format -100xxxxxxxxxx)
ADMIN_CHANNEL_ID=-1001234567890

# (Opsional) ID Topik untuk Notifikasi Order (Jika menggunakan grup dengan topik)
# Kosongkan jika menggunakan Channel biasa
ADMIN_TOPIC_ID=

# (Opsional) ID Topik khusus untuk Log API (Request & Response real-time)
# Kosongkan jika tidak ingin log API di Telegram
ADMIN_API_LOG_TOPIC_ID=

# --- System Configuration ---
# Port untuk Webhook server (Default: 3300)
PORT=3300

# Interval pengecekan stok dalam milidetik (Default: 10000 / 10 detik)
CHECK_INTERVAL=10000

# Set ke 'true' untuk melihat log debug di console
DEBUG=false
